text = "No prefab selected"

[node name="GridScroll" type="ScrollContainer" parent="Margin/Root"]
size_flags_vertical = 3
horizontal_scroll_mode = 0
vertical_scroll_mode = 1

[node name="AssetGrid" type="GridContainer" parent="Margin/Root/GridScroll"]
unique_name_in_owner = true
columns = 2
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="UsageHint" type="RichTextLabel" parent="Margin/Root"]
custom_minimum_size = Vector2(0, 78)
bbcode_enabled = true
fit_content = true
scroll_active = false
text = "[b]Stamp Flow[/b]\nLMB select card, double-click to stamp immediately\nRMB card: open properties (name, scale, category, tags, preview rot)"

