[node name="HeaderRow" type="HBoxContainer" parent="Margin/Root"]

[node name="Header" type="Label" parent="Margin/Root/HeaderRow"]
theme_override_font_sizes/font_size = 18
text = "Library  ▼"

[node name="AssetCount" type="Label" parent="Margin/Root/HeaderRow"]
unique_name_in_owner = true
size_flags_horizontal = 10
horizontal_alignment = 2
text = "0 assets"

[node name="SearchLineEdit" type="LineEdit" parent="Margin/Root"]
unique_name_in_owner = true
placeholder_text = "Search prefabs, e.g. wall stone"

[node name="CategoryTabs" type="ScrollContainer" parent="Margin/Root"]
custom_minimum_size = Vector2(0, 42)
horizontal_scroll_mode = 1
vertical_scroll_mode = 0

[node name="CategoryButtons" type="HBoxContainer" parent="Margin/Root/CategoryTabs"]
